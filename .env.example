# Figma API Configuration
# Get your token here: https://www.figma.com/developers/api#access-tokens
FIGMA_TOKEN=your_personal_access_token_here

# The file ID is in your Figma URLs: https://www.figma.com/design/FILE_ID/...
FIGMA_FILE_ID=your_figma_file_id_here

# (Optional) Format: png, svg, jpg, pdf. Default is png.
# FIGMA_EXPORT_FORMAT=png

# (Optional) Scale for raster images. Default is 2 (Retina).
# FIGMA_EXPORT_SCALE=2

# (Optional) Specific Node IDs to export, comma-separated (e.g. 1:2,3:4)
# If left empty, the script will try to export ALL components in the file.
# FIGMA_NODE_IDS=
